{
  "rules": {
    "users": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        "role": {
          ".validate": "newData.val() === 'client' || newData.val() === 'professional' || (newData.val() === 'admin' && root.child('users').child(auth.uid).child('role').val() === 'admin')"
        }
      }
    },

    "professionals": {
      ".read": true,
      "$pid": {
        ".write": "auth != null && (auth.uid === $pid || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    },

    "profAds": {
      ".read": true,
      ".indexOn": ["professionalId"],
      "$id": {
        ".write": "auth != null && ((newData.exists() && newData.child('professionalId').val() === auth.uid) || (data.exists() && data.child('professionalId').val() === auth.uid) || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    },

    "ads": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },

    "siteSettings": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },

    "requests": {
      ".read": "auth != null",
      ".indexOn": ["clientId", "professionalId"],
      "$id": {
        ".write": "auth != null && ((newData.exists() && newData.child('clientId').val() === auth.uid) || (data.exists() && data.child('professionalId').val() === auth.uid) || (data.exists() && data.child('clientId').val() === auth.uid) || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    }
  }
}
